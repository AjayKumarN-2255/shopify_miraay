{% assign menu = linklists[menu_handle] %}

{% if menu != blank %}
  <ul class="mobile-menu__list">
    {% for link in menu.links %}
      <li class="mobile-menu__item">
        <div class="mobile-menu__row">
          <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>

          {% if link.links != blank %}
            <button class="mobile-menu__toggle" aria-expanded="false" aria-label="Toggle {{ link.title }} submenu">
              <span class="mobile-menu__arrow">⌃</span>
            </button>
          {% endif %}
        </div>

        {% if link.links != blank %}
          <ul class="mobile-menu__submenu">
            {% for child in link.links %}
              <li class="mobile-menu__submenu-item">
                <div class="mobile-menu__row">
                  <a href="{{ child.url }}" class="mobile-menu__submenu-link">{{ child.title }}</a>

                  {% if child.links != blank %}
                    <button
                      class="mobile-menu__toggle"
                      aria-expanded="false"
                      aria-label="Toggle {{ child.title }} submenu"
                    >
                      <span class="mobile-menu__arrow">⌃</span>
                    </button>
                  {% endif %}
                </div>

                {% if child.links != blank %}
                  <ul class="mobile-menu__submenu-child">
                    {% for grandchild in child.links %}
                      <li class="mobile-menu__submenu-child-item">
                        <a href="{{ grandchild.url }}" class="mobile-menu__submenu-child-link">
                          {{ grandchild.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% endif %}

<style>
  .mobile-menu__list,
  .mobile-menu__submenu,
  .mobile-menu__submenu-child {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-menu__item,
  .mobile-menu__submenu-item,
  .mobile-menu__submenu-child-item {
    border-bottom: 1px solid #f2f2f2;
  }

  /* Row wraps the link + arrow button side by side */
  .mobile-menu__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-menu__link,
  .mobile-menu__submenu-link,
  .mobile-menu__submenu-child-link {
    display: block;
    flex: 1;
    text-decoration: none;
    color: var(--menu-text-color);
    font-size: 1rem;
    font-weight: 400;
    padding: 0.75rem 0;
    transition: color 0.3s ease;
  }

  .mobile-menu__submenu-link {
    font-size: 0.95rem;
  }

  .mobile-menu__submenu-child-link {
    font-size: 0.9rem;
    color: #797979;
  }

  /* Arrow is now a standalone button — no link behaviour */
  .mobile-menu__toggle {
    background: none;
    border: none;
    padding: 0.75rem 0 0.75rem 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mobile-menu__arrow {
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    transform: rotate(180deg);
  }

  .mobile-menu__arrow.active {
    transform: rotate(0deg);
  }

  .mobile-menu__submenu,
  .mobile-menu__submenu-child {
    display: none;
  }

  .mobile-menu__submenu.active,
  .mobile-menu__submenu-child.active {
    display: block;
  }

  .mobile-menu__submenu {
    margin-left: 1.25rem;
  }

  .mobile-menu__submenu-child {
    margin-left: 1.25rem;
  }

  .mobile-menu__link:hover,
  .mobile-menu__submenu-link:hover,
  .mobile-menu__submenu-child-link:hover {
    opacity: 0.8;
  }
</style>

<script>
  (function () {
    'use strict';

    function bindToggle(toggleBtn) {
      if (!toggleBtn) return;

      /* The submenu is the next sibling UL of the parent .mobile-menu__row's parent LI */
      const listItem = toggleBtn.closest('li');
      const submenu = listItem.querySelector(':scope > ul');

      if (!submenu) return;

      toggleBtn.addEventListener('click', function () {
        const isOpen = submenu.classList.toggle('active');
        const arrow = this.querySelector('.mobile-menu__arrow');

        if (arrow) arrow.classList.toggle('active', isOpen);
        this.setAttribute('aria-expanded', isOpen);
      });
    }

    document.querySelectorAll('.mobile-menu__toggle').forEach(bindToggle);
  })();
</script>
