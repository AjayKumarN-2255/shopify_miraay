<div class="icon-card" {{ block.shopify_attributes }}>
  {% if block.settings.image %}
    <div class="icon-card-image">
      {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy' }}
    </div>
  {% endif %}

  {% if block.settings.title != blank %}
    <h3 class="icon-card-title">
      {{ block.settings.title }}
    </h3>
  {% endif %}
</div>

<style>
  .icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .icon-card-image {
    width: 6.75rem;
    height: 6.75rem;
  }

  .icon-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .icon-card-title {
    font-size: 1.25rem;
    line-height: 1.75rem;
    color: rgba(18, 18, 18, 0.75);
    letter-spacing: 0.08rem;
    font-weight: 400;
    margin-top: .75rem;
  }

  @media screen and (min-width: 992px) {
    .icon-card-image {
      width: 5rem;
      height: 5rem;
    }

    .icon-card-title {
      font-size: 1rem;
      line-height: 1.75rem;
      color: rgba(18, 18, 18, 0.75);
      letter-spacing: 0.06rem;
      font-weight: 400;
      margin-top: 2rem;
    }
  }
</style>
