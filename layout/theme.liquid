<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {{ content_for_header }}

    <style>
      {{ settings.global_font | font_face }}

        :root {
          --font-global: {{ settings.global_font.family }}, sans-serif;
        }

        *{
          box-sizing: border-box;
          margin: 0;
          padding: 0;
        }

        html{
          font-size: clamp(14px, calc(14px + (100vw - 360px) / 45), 23px);
          scroll-behavior: smooth;
        }

        body {
          font-family: var(--font-global);
          margin: 0;
          padding: 0;
        }

        @media screen and (min-width: 992px){
          html {	font-size: clamp(12px, calc(100vw * 16 / 1500), 23px);
        }
        
    </style>
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>
