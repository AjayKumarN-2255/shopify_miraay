{{ 'carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'banner.js' | asset_url }}" defer></script>

<div
  class="banner"
  data-autoplay="{{ section.settings.autoplay }}"
  style="
    --banner-height: {{ section.settings.banner_height }}dvh;
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  <div class="banner__track">
    {% for block in section.blocks %}
      {% render 'carousel-slide', block: block %}
    {% endfor %}
  </div>

  {% if section.settings.show_arrows %}
    <button class="banner__arrow banner__arrow--prev" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false">
        <path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path>
      </svg>
    </button>

    <button class="banner__arrow banner__arrow--next" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false">
        <path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path>
      </svg>
    </button>
  {% endif %}

  {% if section.settings.show_dots %}
    <div class="banner__dots">
      {% for block in section.blocks %}
        <button
          class="banner__dot {% if forloop.first %}active{% endif %}"
          data-slide="{{ forloop.index0 }}"
          type="button"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Banner Slider",
  "settings": [
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto Slide",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Banner Slider"
    }
  ]
}
{% endschema %}
