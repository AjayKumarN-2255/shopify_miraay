<div
  class="show-case-wrapper"
  style="
    --show-case-height: {{ section.settings.banner_height }}vh;
    --show-case-bg: {{ section.settings.background_color }};
  "
>
  <div class="show-case-container">
    <div class="show-case-content-card">
      {% if section.settings.heading != blank %}
        <h2 class="show-case-title">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="show-case-button"
          style="background-color: {{ section.settings.button_background }};"
        >
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
    <div class="show-case-image-card">
      {% if section.settings.image_1 != blank %}
        <img src="{{ section.settings.image_1 | img_url: '600x600' }}" alt="Image 1">
      {% endif %}
    </div>

    <div class="show-case-image-card">
      {% if section.settings.image_2 != blank %}
        <img src="{{ section.settings.image_2 | img_url: '600x600' }}" alt="Image 2">
      {% endif %}
    </div>
  </div>
</div>

<style>
  .show-case-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--show-case-bg);
    margin-bottom: 2rem;
    padding: 3rem 2rem;
  }

  .show-case-title {
    font-size: 1.75rem;
    line-height: 2.125rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03rem;
    font-weight:400;
  }

  .show-case-button {
    font-weight: 400;
    font-size: 0.938rem;
    line-height: 1.125rem;
    color: white;
    text-align: center;
    border-radius: 0;
    letter-spacing: 0.063rem;
    padding: 0.625rem 2.5rem;
    cursor: pointer;
    background-color: #e1ccb9 !important;
    text-decoration: none;
    transition: 0.3s ease-in-out;
    border: 0.063rem solid #e1ccb9;
    color: black;
  }

  .show-case-button:hover {
    background-color: white !important;
  }

  .show-case-content-card {
    height: 18.5rem;
    flex: 1;
    margin: 2rem 0 1.25rem 0;
  }

  .show-case-container {
    display: flex;
    flex-direction: column;
    width: 58rem;
  }

  .show-case-image-card {
    width: 100%;
    margin: auto;
  }

  .show-case-image-card img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (min-width: 992px) {
    .show-case-wrapper {
      height: var(--show-case-height);
    }

    .show-case-container {
      flex-direction: row;
    }

    .show-case-image-card {
      width: 16.5rem;
      height: 16.5rem;
      margin-left: 0.75rem;
    }

    .show-case-title {
      font-size: 2rem;
      line-height: 3.063rem;
      font-weight: 400;
      letter-spacing: 0.06rem;
      margin-bottom: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Show Case",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#EBF1ED"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height (vh)",
      "min": 30,
      "max": 100,
      "step": 1,
      "default": 57
    },

    {
      "type": "header",
      "content": "Content Card"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for Everyday Luxury"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Image Card 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },

    {
      "type": "header",
      "content": "Image Card 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    }
  ],
  "presets": [
    {
      "name": "Show Case"
    }
  ]
}
{% endschema %}
