{{ 'product-recommend.css' | asset_url | stylesheet_tag }}





{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "class": "section-product-recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Title",
      "default": "Product Recommendations"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width (rem)",
      "min":40,
      "max": 120,
      "step": 2,
      "default": 58
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "recommendation_basis",
      "label": "Recommendation Based On",
      "options": [
        {
          "value": "collection",
          "label": "Same Collection"
        },
        {
          "value": "product_type",
          "label": "Same Product Type"
        },
        {
          "value": "vendor",
          "label": "Same Vendor"
        }
      ],
      "default": "collection"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
