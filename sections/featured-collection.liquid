{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{% assign collection = section.settings.collection %}

<section
  class="featured-collection"
  style="--cols: {{ section.settings.no_of_columns }};"
>
  {% if section.settings.heading != blank %}
    <h2 class="collection_heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div
    class="products-grid"
  >
    {% for product in collection.products limit: section.settings.products_to_show %}
      <div class="product-card">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'card_media' %}
              <div class="product-media">
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              </div>

            {% when 'card_title' %}
              <h3 class="product-title">
                {{ product.title }}
              </h3>

            {% when 'card_price' %}
              <p class="product-price">
                {{ product.price | money }}
              </p>
          {% endcase %}
        {% endfor %}
        <a href="{{ product.url }}" class="view-details-btn"> View Details </a>
      </div>
    {% endfor %}
  </div>
  <div class="view-all-btn-container">
    <a href="{{ product.url }}" class="view-all-products"> View All Products </a>
  </div>
</section>

<style>
  .featured-collection {
    width: 100%;
    margin-bottom: 2.5rem;
  }

  @media screen and (min-width: 992px) {
    .products-grid {
      max-width: {{ section.settings.container_width }}rem;
      grid-template-columns: repeat(var(--cols), 1fr);
    }

  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Most Loved"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width (rem)",
      "min": 60,
      "max": 120,
      "step": 2,
      "default": 70
    },
    {
      "type": "range",
      "id": "no_of_columns",
      "label": "No of columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "blocks": [
    {
      "type": "card_media",
      "name": "Media",
      "limit": 1,
      "settings": []
    },
    {
      "type": "card_title",
      "name": "Product title",
      "limit": 1,
      "settings": []
    },
    {
      "type": "card_price",
      "name": "Price",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid",
      "blocks": [{ "type": "card_media" }, { "type": "card_title" }, { "type": "card_price" }]
    }
  ]
}
{% endschema %}
