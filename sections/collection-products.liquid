{{ 'collection-products.css' | asset_url | stylesheet_tag }}

<section class="collection-products">
  {% paginate collection.products by section.settings.products_per_page %}
    {% if section.settings.show_category_filter or section.settings.show_price_filter %}
      <div class="collection-filters">

        <div class="collection-filters__item">
          {% assign product_types = collection.products | map: 'type' | uniq %}

          <select id="product-type-filter">
            <option value="">Category</option>

            {% for type in product_types %}
              {% if type != blank %}
                <option value="{{ type | handleize }}">
                  {{ type }}
                </option>
              {% endif %}
            {% endfor %}
          </select>
          <svg class="mry-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
        {% if section.settings.show_price_filter %}
          <div class="collection-filters__item">
            <select>
              <option>Price</option>
            </select>
            <svg class="mry-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div class="collection-products__toolbar">
      <div class="collection-products__count">
        {% if collection.products_count <= section.settings.products_per_page %}
          Showing all {{ collection.products_count }} results
        {% else %}
          {% assign per_page = section.settings.products_per_page %}

          {% assign start_index = paginate.current_page | minus: 1 | times: per_page | plus: 1 %}
          {% assign end_index = paginate.current_page | times: per_page %}

          {% if end_index > collection.products_count %}
            {% assign end_index = collection.products_count %}
          {% endif %}

          Showing {{ start_index }}–{{ end_index }} of {{ collection.products_count }} results
        {% endif %}
      </div>

      <form method="get" class="collection-products__sort">
        <div class="select-wrapper">
          <select name="sort_by" onchange="this.form.submit()">
            {% for option in collection.sort_options %}
              <option
                value="{{ option.value }}"
                {% if option.value == collection.sort_by %}
                  selected
                {% endif %}
              >
                {{ option.name }}
              </option>
            {% endfor %}
          </select>
        </div>
      </form>
    </div>

    <div
      class="collection-products__grid"
      style="
        --cols: {{ section.settings.no_of_columns }};
        --container-width: {{ section.settings.container_width }}rem;
      "
    >
      {% for product in collection.products %}
        <div class="collection-products__card">
          <div class="collection-products__media">
            <a href="{{ product.url }}">
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title }}"
              >
            </a>
          </div>

          <h3 class="collection-products__title">
            {{ product.title | truncate: 40 }}
          </h3>

          <p class="collection-products__price">
            {{ product.price | money }}
          </p>

          <form method="post" action="/cart/add" class="collection-products__atc-form">
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
            >

            <button type="submit" class="collection-products__btn">Add to Cart</button>
          </form>
        </div>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div class="collection-pagination">
        {% if paginate.previous %}
          <a class="collection-pagination__prev" href="{{ paginate.previous.url }}"> ← </a>
        {% endif %}

        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a class="collection-pagination__item" href="{{ part.url }}">
              {{ part.title }}
            </a>
          {% else %}
            <span class="collection-pagination__item is-active">
              {{ part.title }}
            </span>
          {% endif %}
        {% endfor %}

        {% if paginate.next %}
          <a class="collection-pagination__next" href="{{ paginate.next.url }}"> → </a>
        {% endif %}
      </div>
    {% endif %}
  {% endpaginate %}
</section>

<style>
  @media screen and (min-width: 992px) {
    .collection-products__grid {
      max-width: {{ section.settings.container_width }}rem;
      grid-template-columns: repeat(var(--cols), 1fr);
    }

    .collection-products__toolbar,
    .collection-filters{
      max-width: {{ section.settings.container_width }}rem;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Product Grid",
  "settings": [
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width (rem)",
      "min": 40,
      "max": 120,
      "step": 2,
      "default": 58
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 8
    },
    {
      "type": "range",
      "id": "no_of_columns",
      "label": "No of products in Single Row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show Category Filter",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price_filter",
      "label": "Show Price Filter",
      "default": false
    }
  ]
}
{% endschema %}
